 * @returns JSX.Element
 */
const Button = ({ Icon, children, additionalClasses = '', ...props }) => (
  <button
    className={`flex items-center space-x-2 px-4 py-2 bg-[#7cac7c] rounded-full hover:bg-[#6b9b6b] transition-colors ${additionalClasses}`}
    {...props}
  >
    {Icon && <Icon size={20} aria-hidden="true" />}
    <span>{children}</span>
  </button>
);

