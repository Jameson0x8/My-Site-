/**
 * Surrounding Circle Component for features like transact, invest, connect
 * @param {object} props
 * @param {string} props.text - Feature name
 * @param {number} props.index - Position index
 * @param {number} props.total - Total number of features
 * @returns JSX.Element
 */
const SurroundingCircle = ({ text, index, total }) => {
  const angle = (index / total) * 2 * Math.PI;
  const radius = 25; // Percentage
  const x = 50 + radius * Math.cos(angle) - 12.5; // Adjusted for element size
  const y = 50 + radius * Math.sin(angle) - 12.5;

  return (
    <div
      className="absolute w-1/4 aspect-square bg-white rounded-full flex flex-col items-center justify-center shadow-md p-2"
      style={{
        top: `${y}%`,
        left: `${x}%`,
      }}
    >
      <h2 className="text-lg font-serif text-[#2f4f4f]">{text}</h2>
      <p className="text-xs text-[#5f9ea0] mt-1 px-2 text-center">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit.
      </p>
    </div>
  );
};

